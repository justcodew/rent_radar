# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://radar:radar_secret_2026@postgres:5432/rent_radar
DATABASE_SYNC_URL=postgresql://radar:radar_secret_2026@postgres:5432/rent_radar
REDIS_URL=redis://redis:6379/0

# ===== Celery =====
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== JWT =====
JWT_SECRET=change-me-in-production-rent-radar-2026
JWT_ACCESS_TTL_MINUTES=10080
JWT_REFRESH_TTL_DAYS=30

# ===== 高德 API(通勤计算) =====
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

# ===== LLM(AI 评分/洞察) =====
LLM_API_KEY=
LLM_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-1.5-flash
LLM_DAILY_BUDGET_CNY=5
LLM_MONTHLY_BUDGET_CNY=100

# ===== 采集配置 =====
# 平台: xhs / douban / wb
CRAWL_PLATFORMS=xhs,douban
CRAWL_INTERVAL_SECONDS=21600
# Chrome CDP(采集需要)
CDP_DEBUG_PORT=9222
ENABLE_CDP_MODE=true

# ===== 应用 =====
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
